# LLM Agent Platform Configuration
# Copy this file to .env and fill in your API keys

# Primary LLM Provider: Groq (free tier available)
# Get your API key at: https://console.groq.com/
GROQ_API_KEY=your_groq_api_key_here

# Optional: OpenRouter as fallback
# Get your API key at: https://openrouter.ai/
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Model Configuration
# Recommended free models on Groq: llama-3.3-70b-versatile, llama-3.1-8b-instant, mixtral-8x7b-32768
DEFAULT_MODEL=llama-3.3-70b-versatile

# Sandbox Configuration
SANDBOX_TIMEOUT=60
SANDBOX_MEMORY_LIMIT=512m
SANDBOX_CPU_LIMIT=1.0

# Logging
LOG_LEVEL=INFO
AUDIT_LOG_DIR=audit_logs
